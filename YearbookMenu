<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dunelm Catholic Yearbook</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- FONT (TeX Gyre Termes alternative) -->
  <link href="https://fonts.googleapis.com/css2?family=Tinos&display=swap" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: 'Tinos', serif;
      background-color: #d8dedd;
      color: #000000;
    }

    /* NAVBAR */
    .navbar {
      background: #003f5e;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .navbar h1 {
      margin: 0;
      font-size: 22px;
      color: white;
    }

    .nav-links a {
      color: white;
      margin: 0 12px;
      text-decoration: none;
      font-size: 16px;
    }

    .nav-links a:hover {
      text-decoration: underline;
    }

    /* HERO */
    .hero {
      text-align: center;
      padding: 70px 20px 40px;
    }

    .hero h2 {
      font-size: 42px;
      margin-bottom: 20px;
    }

    .hero p {
      max-width: 700px;
      margin: auto;
      line-height: 1.7;
      font-size: 18px;
    }

    /* CONTENT */
    .container {
      display: flex;
      flex-wrap: wrap;
      padding: 40px;
      gap: 40px;
      justify-content: center;
    }

    /* YEARBOOK LIST */
    .yearbook-list {
      background: #003f5e;
      color: white;
      padding: 25px 30px;
      border-radius: 12px;
      max-width: 350px;
      width: 100%;
    }

    .yearbook-list h3 {
      margin-top: 0;
      margin-bottom: 15px;
      font-size: 22px;
      color: white;
    }

    .yearbook-list a {
      display: block;
      background: #1e293b;
      color: white;
      padding: 12px 15px;
      border-radius: 8px;
      margin-bottom: 12px;
      text-decoration: none;
      font-size: 17px;
      font-weight: bold;
      transition: background 0.2s ease;
    }

    .yearbook-list a:hover {
      background: #0ea5e9;
    }

    /* CARD */
    .card {
      background: #1e293b;
      padding: 20px;
      border-radius: 12px;
      max-width: 320px;
      text-align: center;
    }

    .card img {
      width: 100%;
      border-radius: 8px;
    }

    .card h3 {
      margin-top: 15px;
      color: white;
    }

    .card p {
      color: white;
    }

    .btn {
      display: inline-block;
      margin-top: 10px;
      padding: 10px 16px;
      background: #38bdf8;
      color: black;
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
    }

    .btn:hover {
      background: #0ea5e9;
    }

  </style>
</head>

<body>

  <!-- NAVBAR -->
  <div class="navbar">
    <h1>Durham University Catholic Society Yearbook Repository</h1>
    <div class="nav-links">
      <a href="#">Yearbooks</a>
      <a href="#">Committees</a>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <h2>Welcome to the Yearbook</h2>
    <p>
      Here are the available Yearbooks of Durham Catholic Society, starting in the Year of Our Lord 2025!
    </p>
  </section>

  <!-- MAIN CONTENT -->
  <div class="container">

    <!-- YEARBOOK LIST BOX -->
    <div class="yearbook-list">
      <h3>Available Yearbooks</h3>
      <a href="2025-2026.html">2025–2026 Yearbook</a>
      <a href="2026-2027.html">2026–2027 Yearbook</a>
    </div>

    <!-- CARD -->
    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Preview">
      <h3>Explore Highlights</h3>
      <p>Browse the best moments from the year.</p>
      <a href="#" class="btn">Read More</a>
    </div>

  </div>

</body>
</html>
